<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Budget"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="16dp" />

        <!-- Category Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Category"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp" />

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout android:id="@+id/cat_food"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍴" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_home"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_transport"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚌" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transport" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_school"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📚" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="School" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/cat_health"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❤️" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Health" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_shopping"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shopping" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_fun"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fun" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_coffee"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☕" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Coffee" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/cat_travel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✈️" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Travel" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_gift"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎁" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gift" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_pet"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5" android:layout_marginEnd="4dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐾" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pet" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cat_other"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="18dp"
                android:background="#F5F5F5"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="···" android:textSize="18sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Other" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Current Budget Info (hidden until category selected) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_budget_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_selected_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Current Budget" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tv_current_limit" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Not set" android:textSize="18sp" android:textStyle="bold" android:textColor="#4A7C7C" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Month Spent" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tv_spent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="€ 0.00" android:textSize="18sp" android:textStyle="bold" android:textColor="#C62828" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Recommendation Button -->
        <Button
            android:id="@+id/btn_ai_recommend"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🤖  Get AI Recommendation"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A7C7C"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- AI Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ai_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F0FAF8"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Recommendation"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#4A7C7C"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_ai_recommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Set Budget Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Budget Amount"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:id="@+id/label_set_budget" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFBEA"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="€"
                    android:textSize="24sp"
                    android:textColor="#B8860B"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_budget_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:textSize="24sp"
                    android:textColor="#B8860B"
                    android:textColorHint="#D4AC30"
                    android:background="@android:color/transparent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_save_budget"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Budget"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

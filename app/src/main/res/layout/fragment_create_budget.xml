<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_budget"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="16dp" />

        <!-- Category Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_category"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="20dp"/>

        <!-- Current Budget Info (hidden until category selected) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_budget_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_selected_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/food"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Current Budget" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tv_current_limit" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/not_set" android:textSize="18sp" android:textStyle="bold" android:textColor="#4A7C7C" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Month Spent" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tv_spent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="€ 0.00" android:textSize="18sp" android:textStyle="bold" android:textColor="#C62828" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Recommendation Button -->
        <Button
            android:id="@+id/btn_ai_recommend"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/get_ai_recommendation"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A7C7C"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- AI Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ai_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F0FAF8"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/get_ai_recommendation"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#4A7C7C"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_ai_recommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Set Budget Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_budget_amount"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:id="@+id/label_set_budget" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFBEA"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/euro"
                    android:textSize="24sp"
                    android:textColor="#B8860B"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_budget_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:textSize="24sp"
                    android:textColor="#B8860B"
                    android:textColorHint="#D4AC30"
                    android:background="@android:color/transparent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_save_budget"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/save_budget"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

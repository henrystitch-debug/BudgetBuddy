<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical"
android:padding="28dp"
android:paddingTop="60dp">

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Pick your currency 💳"
    android:textSize="26sp"
    android:textStyle="bold"
    android:textColor="#1A1A1A"
    android:layout_marginBottom="8dp" />

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="You can change this later in settings."
    android:textSize="14sp"
    android:textColor="#888888"
    android:layout_marginBottom="40dp" />

<!-- Row 1 -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tile_eur"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/eur_symbol" android:textSize="32sp" android:textColor="#1A1A1A" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Euro" android:textSize="13sp" android:textColor="#888888" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tile_usd"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/dollar_symbol" android:textSize="32sp" android:textColor="#1A1A1A" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dollar" android:textSize="13sp" android:textColor="#888888" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

<!-- Row 2 -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tile_gbp"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/br_symbol" android:textSize="32sp" android:textColor="#1A1A1A" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pound" android:textSize="13sp" android:textColor="#888888" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tile_jpy"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/yen_symbol" android:textSize="32sp" android:textColor="#1A1A1A" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Yen" android:textSize="13sp" android:textColor="#888888" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1"
    android:id="@+id/main">

    <TextView
        android:id="@+id/tv_add_expense_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/add_expense"
        android:textSize="48sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cancel"
        android:text="@string/cancel"
        android:textColor="#A32D2D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFF3C4"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_add_expense_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/amount"
                android:textSize="14sp"
                android:textColor="#8a6e00" />

            <EditText
                android:id="@+id/et_amount"
                android:importantForAutofill="no"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                android:hint="@string/number"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:textColor="#4a3800"
                android:textColorHint="#c9a800"
                android:textSize="32sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="#c9a800" />

            <EditText
                android:id="@+id/et_note"
                android:importantForAutofill="no"
                android:inputType="text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                android:hint="@string/add_note"
                android:minHeight="48dp"
                android:textColor="#4a3800"
                android:textColorHint="#c9a800"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_category_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/category"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#4a3800"
        app:layout_constraintTop_toBottomOf="@+id/card_amount"
        app:layout_constraintStart_toStartOf="parent" />

    <GridLayout
        android:id="@+id/grid_categories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:columnCount="4"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@+id/tv_category_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_food"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/food"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/food"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_home"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/home"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_transport"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/transport"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/transport"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_school"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/school"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/school"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_health"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/health"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/health"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_shopping"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/shopping"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/shopping"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_entertainment"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/entertainment"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/fun"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/btn_cat_other"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_change_circle_24"
                android:background="#FFF3C4"
                android:contentDescription="@string/other"
                android:scaleType="centerInside"
                app:tint="#4a3800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/other"
                android:textSize="12sp"
                android:textColor="#4a3800" />
        </LinearLayout>

    </GridLayout>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="32dp"
        android:text="@string/save_expense"
        android:textColor="#FFF8E1"
        android:backgroundTint="#4a3800"
        android:contentDescription="@string/save_expense"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
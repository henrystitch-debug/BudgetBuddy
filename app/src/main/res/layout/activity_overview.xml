<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F1"
    android:id="@+id/main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_overview_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:text="@string/overview"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#1B3A1B" />

        <TextView
            android:id="@+id/tv_month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:text="@string/placeholder"
            android:textSize="14sp"
            android:textColor="#4a7a4a" />

        <!-- Flame streak card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_streak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fire"
                    android:textSize="40sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A1B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/you_stayed_in_budget"
                        android:textSize="12sp"
                        android:textColor="#4a7a4a" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/number"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#E65100" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Donut chart card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/spending_breakdown"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B3A1B" />

                <!-- Donut chart placeholder -->
                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="center"
                        app:indicatorSize="180dp"
                        app:trackThickness="24dp"
                        app:indicatorColor="#3B6D11"
                        app:trackColor="#E8F5E9"
                        android:progress="40"
                        android:contentDescription="@string/spending_chart" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/number"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1B3A1B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_spent"
                            android:textSize="11sp"
                            android:textColor="#4a7a4a" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="12dp">
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#3B6D11" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/food"
                            android:textSize="12sp"
                            android:textColor="#1B3A1B" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="12dp">
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#5C92A8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/home"
                            android:textSize="12sp"
                            android:textColor="#1B3A1B" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#A32D2D" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/other"
                            android:textSize="12sp"
                            android:textColor="#1B3A1B" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Category progress bars card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/budget_progress"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B3A1B"
                    android:layout_marginBottom="16dp" />

                <!-- Food -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/food"
                        android:textSize="13sp"
                        android:textColor="#1B3A1B" />
                    <ProgressBar
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progress="65"
                        android:progressTint="#3B6D11"
                        android:trackTint="#E8F5E9" />
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/number"
                        android:textSize="12sp"
                        android:textColor="#4a7a4a" />
                </LinearLayout>

                <!-- Transport -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/transport"
                        android:textSize="13sp"
                        android:textColor="#1B3A1B" />
                    <ProgressBar
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progress="30"
                        android:progressTint="#3B6D11"
                        android:trackTint="#E8F5E9" />
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/number"
                        android:textSize="12sp"
                        android:textColor="#4a7a4a" />
                </LinearLayout>

                <!-- Home -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/home"
                        android:textSize="13sp"
                        android:textColor="#1B3A1B" />
                    <ProgressBar
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progress="90"
                        android:progressTint="#A32D2D"
                        android:trackTint="#E8F5E9" />
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/number"
                        android:textSize="12sp"
                        android:textColor="#A32D2D" />
                </LinearLayout>

                <!-- Shopping -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/shopping"
                        android:textSize="13sp"
                        android:textColor="#1B3A1B" />
                    <ProgressBar
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progress="50"
                        android:progressTint="#BA7517"
                        android:trackTint="#E8F5E9" />
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/number"
                        android:textSize="12sp"
                        android:textColor="#BA7517" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Past expenses card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_expenses_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_expenses"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A1B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textSize="13sp"
                        android:textColor="#3B6D11" />

                </LinearLayout>

                <!-- Expense row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/outline_change_circle_24"
                        android:background="#E8F5E9"
                        android:padding="8dp"
                        android:contentDescription="@string/food" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shopping"
                            android:textSize="14sp"
                            android:textColor="#1B3A1B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder"
                            android:textSize="12sp"
                            android:textColor="#4a7a4a" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/number"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#A32D2D" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#E0E0E0" />

                <!-- Expense row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/outline_change_circle_24"
                        android:background="#E8F5E9"
                        android:padding="8dp"
                        android:contentDescription="@string/transport" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transport"
                            android:textSize="14sp"
                            android:textColor="#1B3A1B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder"
                            android:textSize="12sp"
                            android:textColor="#4a7a4a" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/number"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#A32D2D" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#E0E0E0" />

                <!-- Expense row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/outline_change_circle_24"
                        android:background="#E8F5E9"
                        android:padding="8dp"
                        android:contentDescription="@string/home" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/electricity"
                            android:textSize="14sp"
                            android:textColor="#1B3A1B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder"
                            android:textSize="12sp"
                            android:textColor="#4a7a4a" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/number"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#A32D2D" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>